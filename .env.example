# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MIDTRANS_SERVER_KEY: Server key from Midtrans Dashboard (Sandbox or Production)
MIDTRANS_SERVER_KEY=""

# MIDTRANS_CLIENT_KEY: Client key from Midtrans Dashboard (Sandbox or Production)
MIDTRANS_CLIENT_KEY=""

# MIDTRANS_IS_PRODUCTION: Set to "true" for production, "false" or empty for sandbox
MIDTRANS_IS_PRODUCTION="false"
